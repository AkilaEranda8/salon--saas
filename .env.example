# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in all required values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=db
DB_USER=root
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_NAME=zanesalon

# ── JWT (min 32 random chars — generate with: openssl rand -hex 32) ──────────
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHAR_RANDOM_STRING

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=https://{slug}.salon.hexalyte.com
PLATFORM_URL=https://admin.hexalyte.com

# ── Email / SMTP (optional — reminders and invoices) ─────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password

# ── Twilio SMS/WhatsApp (optional) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+1XXXXXXXXXX

# ── Firebase FCM Push Notifications (optional) ───────────────────────────────
# Paste entire Firebase service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Stripe Billing (optional — disable if not using Stripe) ──────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Docker port bindings (optional overrides) ─────────────────────────────────
BACKEND_PORT=5001
